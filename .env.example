# ==============================================
# LLEEVAMEQ BACKEND - VARIABLES DE ENTORNO
# ==============================================

# Base de datos PostgreSQL
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=lleevameq
DATABASE_PASSWORD=lleevameq123
DATABASE_NAME=lleevameq

# Para Railway (usar DATABASE_URL en producción)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=tu-super-secreto-muy-largo-y-aleatorio-cambiar-en-produccion-123456789
JWT_EXPIRES_IN=7d

# Aplicación
PORT=3000
NODE_ENV=development

# WebSocket
WS_PORT=3001

# Matching (radio en kilómetros)
MATCHING_RADIUS_KM=5
MATCHING_TIMEOUT_SECONDS=30

# Tarifas (en COP - Pesos colombianos)
TARIFA_BASE=3000
TARIFA_POR_KM=1500
TARIFA_POR_MINUTO=200
TARIFA_MINIMA=4000
RECARGO_NOCTURNO=1.2
RECARGO_HORA_PICO=1.3

# Horarios
HORA_NOCTURNA_INICIO=22
HORA_NOCTURNA_FIN=6
HORA_PICO_MANANA_INICIO=7
HORA_PICO_MANANA_FIN=9
HORA_PICO_TARDE_INICIO=17
HORA_PICO_TARDE_FIN=19

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# Logging
LOG_LEVEL=debug
